# Database
DATABASE_URL=postgresql+asyncpg://safecity:safecity_secret_2024@localhost:5432/safecity

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Brevo SMS
BREVO_API_KEY=your-brevo-api-key

# Firebase
FIREBASE_CREDENTIALS_PATH=Safe City Firebase Admin SDK.json

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=safe-sity

# Admin Bootstrapping (Used for initial setup on Heroku/Local)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=your_secure_password
# BOOTSTRAP_COMPANY_NAME=My Security Company
# BOOTSTRAP_GLOBAL_ADMIN_EMAIL=superadmin@safecity.kz
# BOOTSTRAP_GLOBAL_ADMIN_PASSWORD=change_this_immediately

# Robokassa (Kazakhstan) — get these from Мои магазины -> Технические настройки
ROBOKASSA_MERCHANT_LOGIN=Safe-City.kz
ROBOKASSA_PASSWORD1=your-password-1
ROBOKASSA_PASSWORD2=your-password-2
ROBOKASSA_IS_TEST=true
ROBOKASSA_HASH_ALGO=sha256
# ROBOKASSA_PAYMENT_URL=https://auth.robokassa.kz/Merchant/Index.aspx
# ROBOKASSA_RECURRING_URL=https://auth.robokassa.kz/Merchant/Recurring
# KZ receipt tax tag: none | vat0 | vat5 | vat12 | vat16 (use vat12 only if you are a VAT payer)
ROBOKASSA_VAT=none
# Optional frontend redirect targets after payment
# PAYMENT_SUCCESS_REDIRECT=https://safe-city.kz/pay/success
# PAYMENT_FAIL_REDIRECT=https://safe-city.kz/pay/fail

# Public HTTPS origin of this deployment (no trailing slash).
# Required for the Telegram webhook to be registered on startup.
PUBLIC_BASE_URL=https://safe-city-back.herokuapp.com

# Telegram admin bot — runs inside this same web process, no extra dyno.
# Token from @BotFather; leave empty to disable the bot entirely.
TELEGRAM_BOT_TOKEN=
# Chat ids allowed to use /stats and receiving new-subscription alerts.
# Send /id in the chat to find out its id. Comma-separated. Group ids are
# negative; add ":<topic_id>" to post into a specific forum topic, e.g.
# TELEGRAM_ADMIN_CHAT_IDS=123456789,-1002345678901:15
TELEGRAM_ADMIN_CHAT_IDS=
# Optional; derived from the bot token when empty.
# TELEGRAM_WEBHOOK_SECRET=

